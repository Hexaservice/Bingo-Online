rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSystemRequest() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(email) {
      return isSignedIn() && request.auth.token.email == email;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    function hasRole(rolesPermitidos) {
      return isSignedIn()
        && currentUserDoc().exists()
        && rolesPermitidos.hasAny([currentUserDoc().data.role]);
    }

    function isAdmin() {
      return isSystemRequest() || hasRole(['Superadmin', 'Administrador']);
    }

    function hasStrongRole(roleEsperado) {
      return isSignedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.role == roleEsperado
          || (request.auth.token.roles is list && request.auth.token.roles.hasAny([roleEsperado]))
        );
    }

    function isStrongSuperadmin() {
      return hasStrongRole('Superadmin');
    }

    function canManageGlobalParams() {
      return isSignedIn()
        && request.auth.token.canManageGlobalParams == true
        && request.auth.token.email == 'jhoseph.q@gmail.com';
    }

    function isPrivilegedOperator() {
      return isAdmin() || hasRole(['Colaborador']);
    }

    function isProductionLockEnabled() {
      return exists(/databases/$(database)/documents/Variablesglobales/Parametros)
        && get(/databases/$(database)/documents/Variablesglobales/Parametros).data.bloquearEscriturasClientePremios == true;
    }



    function isLiveRadioStatusValid(value) {
      return value in ['offline', 'starting', 'live', 'paused', 'ended'];
    }

    function isLiveRadioSchemaValid(data) {
      return data.keys().hasAll(['enabled', 'status', 'streamUrl', 'title', 'hostName', 'startedAt', 'updatedAt', 'requireAuth', 'version'])
        && data.enabled is bool
        && data.status is string
        && isLiveRadioStatusValid(data.status)
        && data.streamUrl is string
        && (data.status == 'live' ? data.streamUrl.size() > 0 : true)
        && data.title is string
        && data.hostName is string
        && data.requireAuth is bool
        && data.version is int
        && data.startedAt is timestamp
        && data.updatedAt is timestamp;
    }

    function canReadLiveRadio(docData) {
      return isSignedIn()
        && hasRole(['Jugador', 'Colaborador', 'Administrador', 'Superadmin'])
        && (docData.requireAuth == true ? hasRole(['Jugador', 'Colaborador', 'Administrador', 'Superadmin']) : true);
    }

    function blockedUserFields() {
      return ['role', 'disabled', 'contrasenasu', 'emailVerified', 'customClaims', 'uid'];
    }

    function touchesBlockedUserFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny(blockedUserFields());
    }

    function createsBlockedUserFields() {
      return request.resource.data.keys().hasAny(blockedUserFields());
    }

    match /users/{email} {
      allow read: if isOwner(email) || isSystemRequest();
      allow create: if isAdmin() || (isOwner(email) && !createsBlockedUserFields());
      allow update: if isAdmin() || (isOwner(email) && !touchesBlockedUserFields());
      allow delete: if isAdmin();

      match /role/{docId} {
        allow read, write: if isSystemRequest();
      }

      match /premios/{premioId} {
        allow read: if isOwner(email) || isAdmin();
        allow write: if isSystemRequest() || isPrivilegedOperator();
      }

      match /billeteraProyeccion/{docId} {
        allow read: if isOwner(email) || isAdmin();
        allow write: if isSystemRequest() || isPrivilegedOperator();
      }
    }

    match /sorteos/{sorteoId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isPrivilegedOperator();
    }

    match /Billetera/{email} {
      allow read: if isAdmin() || isOwner(email);
      allow create, update: if isSystemRequest()
        || (!isProductionLockEnabled() && (isAdmin() || isOwner(email) || isPrivilegedOperator()));
      allow delete: if isAdmin();
    }

    match /Variablesglobales/{docId} {
      allow read: if docId == 'Parametros' ? isStrongSuperadmin() : isSignedIn();
      allow write: if docId == 'Parametros'
        ? (isStrongSuperadmin() && canManageGlobalParams())
        : isAdmin();
    }


    match /global/liveRadio {
      allow read: if canReadLiveRadio(resource.data);
      allow create, update: if isPrivilegedOperator() && isLiveRadioSchemaValid(request.resource.data);
      allow delete: if isAdmin();
    }

    match /roles/{docId} {
      allow read, write: if isSystemRequest();
    }

    match /transacciones/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.IDbilletera == request.auth.token.email);
      allow create: if isSystemRequest()
        || (!isProductionLockEnabled() && (isAdmin()
          || (isSignedIn() && request.resource.data.IDbilletera == request.auth.token.email)
          || (isPrivilegedOperator() && request.resource.data.tipotrans == 'premio')));
      allow update: if isSystemRequest()
        || (!isProductionLockEnabled() && (isAdmin()
          || (isPrivilegedOperator()
            && resource.data.tipotrans == 'premio'
            && request.resource.data.tipotrans == 'premio')));
      allow delete: if isAdmin();
    }

    match /CartonGuardado/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /CartonJugado/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /Bancos/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /PagosAdministracion/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /PagosAdministracionArchivo/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /PremiosSorteos/{docId} {
      allow read: if isSignedIn();
      allow write: if isSystemRequest() || (!isProductionLockEnabled() && isPrivilegedOperator());
    }

    match /PremiosSorteosArchivo/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /Referidos/{email} {
      allow read: if isAdmin() || isOwner(email);
      allow create, update: if isAdmin() || isOwner(email);
      allow delete: if isAdmin();

      match /campanas/{campanaId} {
        allow read: if isAdmin() || isOwner(email);
        allow create, update: if isAdmin() || isOwner(email);
        allow delete: if isAdmin();
      }
    }

    match /SorteosCentroPagos/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /campanas/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /campanasReferidos/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /cantarsorteos/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /cantos/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /formas/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator();
    }

    match /posts/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /pqrs/{docId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if isSignedIn() && request.resource.data.email == request.auth.token.email;
      allow update, delete: if isAdmin();
    }

    match /SimulacionesSorteo/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivilegedOperator()
        || (
          isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && docId.matches('^[^_]+_' + request.auth.uid + '$')
        );
    }

    // Colecciones técnicas de operación (CentroPagos/CantarSorteos y procesos internos)
    match /AcreditacionesPendientes/{docId} {
      allow read, write: if isSystemRequest() || isPrivilegedOperator();
    }

    match /AcreditacionesPendientesAuditoria/{docId} {
      allow read, write: if isSystemRequest() || isPrivilegedOperator();
    }

    match /AcreditacionAuditoriaTecnica/{docId} {
      allow read, write: if isSystemRequest();
    }

    match /AcreditacionReconciliacionPendiente/{docId} {
      allow read, write: if isSystemRequest();
    }

    match /GanadoresSorteosTiempoReal/{docId} {
      allow read, write: if isSystemRequest() || isPrivilegedOperator();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
